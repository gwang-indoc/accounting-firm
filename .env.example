# File upload configuration
# Directory where uploaded files are stored (absolute or relative path)
UPLOAD_DIR=./uploads

# Maximum file size allowed per upload, in megabytes
UPLOAD_MAX_FILE_SIZE_MB=10

# Maximum number of characters allowed in an uploaded filename
UPLOAD_MAX_FILENAME_LENGTH=100

# Comma-separated list of blocked file extensions (no dots)
BLOCKED_EXTENSIONS=exe,js
